# Optional: seed API keys via environment variables.
# In normal use you enter these in the app's Settings dialog instead; they are
# then stored in the Electron userData settings.json (not in this repo).
# Copy to ".env" only if you wire up dotenv yourself — the app reads these as
# fallback defaults on first run (see src/main/settings.js).

# Speech-to-text (required)
DEEPGRAM_API_KEY=

# Answer providers (configure at least one)
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
# Ollama runs locally and needs no key; default base URL:
# OLLAMA_BASE_URL=http://localhost:11434/v1/chat/completions
